{
  "suite": "golden-journeys",
  "version": 2,
  "description": "Golden journey vectors: a wire-format campaign + flow (journey handlers) + a scripted timeline → the ordered subsequence of tracked events the SDK must emit and the number of journeys left active. Runners drive a REAL journey service (mock transport/renderer, controllable clock) and assert the emission order with an ordered-subsequence match so incidental internal events never break the contract. Version 2 adds clock-advance steps (advance_clock_seconds), mid-timeline absence checkpoints (assert_absent), profile experiment reassignment (set_experiments), per-vector server experiment assignments (experiments), and exact emission counts (event_counts).",
  "distinct_id": "golden_user",
  "vectors": [
    {
      "name": "event-trigger-runs-entry-actions-and-completes",
      "campaign": {
        "id": "campaign-golden-1",
        "name": "Golden Entry Actions",
        "flowId": "flow-golden-1",
        "flowNumber": 1,
        "reentry": { "type": "every_time" },
        "publishedAt": "2026-01-01T00:00:00Z",
        "trigger": { "type": "event", "config": { "eventName": "golden_start" } }
      },
      "flow": {
        "id": "flow-golden-1",
        "flowArtifact": {
          "url": "https://example.com/builds/flow-golden-1",
          "buildId": "build-flow-golden-1",
          "manifest": { "totalFiles": 0, "totalSize": 0, "contentHash": "golden-hash", "files": [] }
        },
        "screens": [{ "id": "screen-1" }],
        "events": {},
        "scripts": {},
        "handlers": {
          "__journey__": [
            {
              "id": "h-entry",
              "eventName": "golden_start",
              "actions": [
                {
                  "type": "send_event",
                  "eventName": "golden_side_effect",
                  "properties": { "source": "golden-journey" }
                },
                { "type": "exit" }
              ]
            }
          ]
        }
      },
      "timeline": [
        { "track": { "name": "golden_start", "properties": {} } }
      ],
      "expect": {
        "ordered_event_subsequence": [
          "$journey_start",
          "golden_side_effect",
          "$journey_completed"
        ],
        "active_journeys_after": 0
      }
    },
