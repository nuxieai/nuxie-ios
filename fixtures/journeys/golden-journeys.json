        },
        "screens": [{ "id": "screen-1" }],
        "events": {},
        "scripts": {},
        "handlers": {
          "__journey__": [
            {
              "id": "h-entry",
              "eventName": "golden_delay_start",
              "actions": [
                { "type": "delay", "durationMs": 60000 },
                { "type": "send_event", "eventName": "golden_delayed_effect" },
                { "type": "exit" }
              ]
            }
          ]
        }
      },
      "timeline": [
        { "track": { "name": "golden_delay_start", "properties": {} } },
        { "assert_absent": ["golden_delayed_effect", "$journey_completed"] },
        { "advance_clock_seconds": 59 },
        { "assert_absent": ["golden_delayed_effect", "$journey_completed"] },
        { "advance_clock_seconds": 1 }
      ],
      "expect": {
        "ordered_event_subsequence": [
          "$journey_start",
          "$journey_paused",
          "golden_delayed_effect",
          "$journey_completed"
        ],
        "event_counts": {
          "golden_delayed_effect": 1,
          "$journey_resumed": 1
        },
        "active_journeys_after": 0
      }
